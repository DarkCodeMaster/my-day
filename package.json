{
  "name": "myday",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:preview": "npm run build && electron .",
    "icon": "node scripts/make-icon.mjs"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "@vueup/vue-quill": "^1.5.5",
    "animal-island-vue": "file:../animal-island-vue",
    "dompurify": "^3.4.12",
    "echarts": "^6.1.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.7",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "com.example.myday",
    "productName": "MyDay",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [],
    "asar": true,
    "win": {
      "target": "nsis",
      "signAndEditExecutable": true,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MyDay"
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      },
      "icon": "build/icon.png"
    },
    "publish": null
  }
}
